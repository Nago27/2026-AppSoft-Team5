@page "/"
@page "/login"
@layout TodoRPG.Web.Client.Layout.LoginLayout
@using System.ComponentModel.DataAnnotations
@using System.Text
@using System.Text.Json
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Login - TodoRPG</PageTitle>

<div class="login-card @(isOpening ? "is-opening" : "")">
    <h1 class="login-title">TodoRPG</h1>

    <EditForm Model="@model" OnValidSubmit="@HandleLogin" FormName="login" class="login-form">
        <DataAnnotationsValidator />

        <div class="field">
            <label for="username">ID</label>
            <InputText id="username"
                       class="form-control"
                       @bind-Value="model.Username"
                       autocomplete="username"
                       disabled="@(isOpening || isSubmitting)" />
            <ValidationMessage For="@(() => model.Username)" />
        </div>

        <div class="field">
            <label for="password">Password</label>
            <InputText id="password"
                       type="password"
                       class="form-control"
                       @bind-Value="model.Password"
                       autocomplete="current-password"
                       disabled="@(isOpening || isSubmitting)" />
            <ValidationMessage For="@(() => model.Password)" />
        </div>

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="error">@errorMessage</div>
        }

        <button type="submit" class="btn-login" disabled="@(isOpening || isSubmitting)">
            @(isOpening ? "Opening..." : isSubmitting ? "Checking..." : "Login")
        </button>

        <div class="signup-row">
            <a href="/signup">회원가입</a>
        </div>
    </EditForm>
</div>

@if (isOpening)
{
    <div class="door-transition" aria-hidden="true">
        <div class="door-frame">
            <div class="door-light"></div>

            <div class="door-panel door-left">
                <span></span>
                <span></span>
                <span></span>
            </div>

            <div class="door-panel door-right">
                <span></span>
                <span></span>
                <span></span>
            </div>

            <div class="door-player">
                <div class="player-head"></div>
                <div class="player-body"></div>
            </div>

            <div class="floor-light"></div>
        </div>
    </div>
}

@code {
    private LoginModel model = new();
    private string? errorMessage;
    private bool isOpening;
    private bool isSubmitting;

    private async Task HandleLogin()
    {
        if (isOpening || isSubmitting)
        {
            return;
        }

        errorMessage = null;
        isSubmitting = true;

        try
        {
            var loginRequest = new
            {
                Id = model.Username.Trim(),
                Password = model.Password
            };

            var json = JsonSerializer.Serialize(loginRequest);

            var content = new StringContent(
                json,
                Encoding.UTF8,
                "application/json"
            );

            var response = await Http.PostAsync("api/User/login", content);

            if (!response.IsSuccessStatusCode)
            {
                var responseText = await response.Content.ReadAsStringAsync();

                errorMessage = string.IsNullOrWhiteSpace(responseText)
                    ? "ID 또는 비밀번호가 올바르지 않습니다."
                    : responseText.Trim('"');

                return;
            }

            await JS.InvokeVoidAsync(
                "sessionStorage.setItem",
                "todoRpg_user_id",
                model.Username.Trim()
            );

            isOpening = true;

            await Task.Delay(2300);

            Navigation.NavigateTo("/home");
        }
        catch (Exception ex)
        {
            errorMessage = $"API 연결 실패: {ex.Message}";
        }
        finally
        {
            if (!isOpening)
            {
                isSubmitting = false;
            }
        }
    }

    private sealed class LoginModel
    {
        [Required(ErrorMessage = "ID를 입력하세요.")]
        public string Username { get; set; } = string.Empty;

        [Required(ErrorMessage = "비밀번호를 입력하세요.")]
        public string Password { get; set; } = string.Empty;
    }
}